TRMNL_AGENT_USAGE_CACHE_DIR=/path/to/cache/trmnl-agent-usage
TRMNL_AGENT_USAGE_TIMEZONE=UTC

# Optional. Leave false to fetch current prices; set true to use ccusage's built-in prices offline.
TRMNL_AGENT_USAGE_OFFLINE=false

# Optional. Changes titles only; plan names still come from Codex or Claude Code.
# TRMNL_AGENT_USAGE_CODEX_TITLE=Codex Usage
# TRMNL_AGENT_USAGE_CLAUDE_TITLE=Claude Code Usage

# Optional. Set true only to fill missing reset-credit expiry from an unofficial source.
TRMNL_AGENT_USAGE_ENABLE_CODEX_PRIVATE_RESET_CREDITS=false

# Optional. Read current Claude limits directly from Anthropic. The access token stays in
# memory and is sent only to Anthropic.
TRMNL_AGENT_USAGE_ENABLE_CLAUDE_OAUTH_USAGE=false

# Optional. Requires the OAuth usage setting above; it does nothing on its own.
# If no command-line Claude request runs for about eight hours, the limit percentages become
# unavailable. This runs one minimal prompt so Claude Code renews its own stored access token,
# which consumes real Claude usage and may incur a charge. Your login itself does not expire.
TRMNL_AGENT_USAGE_ENABLE_CLAUDE_OAUTH_REFRESH=false

# Optional. Minutes before access-token expiry to run the refresh prompt. Default 0 waits for real
# expiry, because Claude Code renews an expired token, not a nearly expired one.
TRMNL_AGENT_USAGE_CLAUDE_OAUTH_REFRESH_SKEW_MINUTES=0

# Optional. Minimum minutes between refresh attempts.
TRMNL_AGENT_USAGE_CLAUDE_OAUTH_REFRESH_COOLDOWN_MINUTES=30

# Optional. Model used for the refresh prompt. Keep this on the cheapest available model.
# TRMNL_AGENT_USAGE_CLAUDE_OAUTH_REFRESH_MODEL=claude-haiku-4-5-20251001

# Optional. Also run your existing Claude status-line command after capturing limit data.
TRMNL_AGENT_USAGE_CLAUDE_STATUSLINE_DELEGATE=/path/to/existing/statusline-command.sh

# Optional. Stop trusting captured Claude limit percentages older than this many minutes. A
# still-future reset time is kept as timing context.
TRMNL_AGENT_USAGE_CLAUDE_STATUSLINE_MAX_AGE_MINUTES=30

# Optional. TRMNL SaaS Private Plugin webhook URLs. Treat these URLs like passwords.
TRMNL_AGENT_USAGE_CODEX_WEBHOOK_URL=https://trmnl.com/api/custom_plugins/REPLACE_ME
TRMNL_AGENT_USAGE_CLAUDE_WEBHOOK_URL=https://trmnl.com/api/custom_plugins/REPLACE_ME
