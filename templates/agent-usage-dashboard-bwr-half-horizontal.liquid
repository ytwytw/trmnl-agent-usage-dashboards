<style>
  .agent-usage-screen, .agent-usage-screen * { box-sizing: border-box; }
  .agent-usage-screen { color-scheme: light; width: 800px; height: 225px; padding: 8px; display: grid; grid-template-rows: 30px 62px 69px 24px; gap: 8px; font-family: Inter, Arial, sans-serif; overflow: hidden; }
  .agent-usage-screen .top, .agent-usage-screen .foot { display: grid; grid-template-columns: 1fr auto; gap: 10px; align-items: center; border-bottom: 3px solid #000; font-weight: 900; min-width: 0; }
  .agent-usage-screen .foot { border-top: 2px solid #000; border-bottom: 0; font-size: 12px; }
  .agent-usage-screen .title { font-size: 26px; line-height: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .agent-usage-screen .meta { font-size: 12px; white-space: nowrap; text-align: right; }
  .agent-usage-screen .limits, .agent-usage-screen .metrics { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 8px; }
  .agent-usage-screen .card { min-width: 0; border-top: 2px solid #000; padding-top: 4px; overflow: hidden; }
  .agent-usage-screen .label { font-size: 11px; line-height: 1; font-weight: 900; text-transform: uppercase; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .agent-usage-screen .value { margin-top: 2px; font-size: 24px; line-height: .95; font-weight: 900; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .agent-usage-screen .sub { margin-top: 2px; font-size: 11px; line-height: 1; font-weight: 800; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .agent-usage-screen .bar { height: 9px; margin-top: 4px; border: 2px solid #000; background: #fff; }
  .agent-usage-screen .fill { height: 100%; background: repeating-linear-gradient(90deg, #000 0 2px, #fff 2px 4px); }
</style>

{% assign s = source_1 %}
{% assign banked_count = s.credits.banked_reset_summary | split: ' @ ' | first %}
{% assign banked_expiry = s.credits.banked_reset_summary | split: ' @ ' | last %}
<div class="agent-usage-screen">
  <header class="top">
    <div class="title">{{ s.title }}</div>
    <div class="meta">{{ s.local_datetime }} · {{ s.cost_basis }}</div>
  </header>

  <section class="limits">
    <div class="card">
      <div class="label">{{ s.limits.primary.label }}</div>
      <div class="value">{{ s.limits.primary.used }}</div>
      <div class="sub">reset {{ s.limits.primary.reset }}</div>
    </div>
    <div class="card">
      <div class="label">{{ s.limits.weekly.label }}</div>
      <div class="value">{{ s.limits.weekly.used }}</div>
      <div class="sub">reset {{ s.limits.weekly.reset }}</div>
    </div>
    <div class="card">
      <div class="label">{{ s.usage.five_hour.label }}</div>
      <div class="value">{{ s.usage.five_hour.total }}</div>
      <div class="sub">{{ s.usage.five_hour.cost }} · cache {{ s.usage.five_hour.cache_hit }}</div>
    </div>
    <div class="card">
      <div class="label">{% if s.kind == 'codex' %}Banked{% else %}{{ s.limits.scoped.label }}{% endif %}</div>
      <div class="value">{% if s.kind == 'codex' %}{{ banked_count }}{% else %}{{ s.limits.scoped.used }}{% endif %}</div>
      <div class="sub">{% if s.kind == 'codex' %}{% if s.credits.banked_reset_summary contains ' @ ' %}@ {{ banked_expiry }}{% else %}{{ s.credits.banked_reset_summary }}{% endif %}{% else %}reset {{ s.limits.scoped.reset }}{% endif %}</div>
    </div>
  </section>

  <section class="metrics">
    <div class="card"><div class="label">Today</div><div class="value">{{ s.usage.today.total }}</div><div class="sub">Token Cost* {{ s.usage.today.cost }}</div></div>
    <div class="card"><div class="label">Local 7d</div><div class="value">{{ s.usage.week.total }}</div><div class="sub">Token Cost* {{ s.usage.week.cost }}</div></div>
    <div class="card"><div class="label">Local month</div><div class="value">{{ s.usage.month.total }}</div><div class="sub">{% if s.account_usage.lifetime %}account {{ s.account_usage.lifetime }}{% else %}local all {{ s.usage.all.total }}{% endif %}</div></div>
    <div class="card"><div class="label">Top model</div><div class="value">{{ s.models[0].tokens }}</div><div class="sub">{{ s.models[0].name }}</div></div>
  </section>

  <footer class="foot">
    <div>{{ s.source }}</div>
    <div>{{ s.sessions.today }}/{{ s.sessions.week }}/{{ s.sessions.all }} sessions</div>
  </footer>
</div>
